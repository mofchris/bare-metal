{
  // Strict everywhere: the data-heavy parts of this app (curriculum, progress,
  // SRS state) are exactly where loose types hide bugs (see D-003).
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    // tools/ run directly under Node's native TypeScript type-stripping
    // (no ts-node/tsx dependency, see D-015); that requires relative imports
    // to carry their .ts extension, which needs this flag.
    "allowImportingTsExtensions": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src", "tools", "vite.config.ts"]
}
