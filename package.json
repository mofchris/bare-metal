{
  "name": "metal",
  "version": "0.1.0",
  "private": true,
  "description": "Metal — a self-contained, offline-capable MLSys learning platform",
  "type": "module",
  "scripts": {
    "dev": "npm run build:content && vite",
    "build:content": "node tools/content-compiler/cli.ts",
    "build": "npm run build:content && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "idb": "^8.0.3",
    "preact": "^10.27.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@types/node": "^24.0.0",
    "fake-indexeddb": "^6.2.5",
    "marked": "^16.0.0",
    "prettier": "^3.6.0",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "yaml": "^2.8.0"
  }
}
